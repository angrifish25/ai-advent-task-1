# ===========================================
# AI CLI Assistant - Конфигурация
# ===========================================

# API ключ (обязательно)
# Для OpenAI: https://platform.openai.com/api-keys
# Для локальных моделей: любое значение (например, "not-needed")
OPENAI_API_KEY=sk-your-api-key-here

# Базовый URL API (опционально)
# По умолчанию: https://api.openai.com/v1
#
# Примеры для локальных моделей:
# - LM Studio: http://localhost:1234/v1
# - Ollama: http://localhost:11434/v1
# - vLLM: http://localhost:8000/v1
# OPENAI_BASE_URL=http://localhost:1234/v1

# Модель по умолчанию (опционально, можно переопределить через --model)
# OPENAI_DEFAULT_MODEL=gpt-3.5-turbo

# --- Параметры модели (переопределяются аргументами CLI) ---

# Модель по умолчанию
# OPENAI_DEFAULT_MODEL=gpt-4o
# OPENAI_DEFAULT_MODEL=gpt-4o

# Системный промпт по умолчанию
# LLM_SYSTEM_PROMPT=Ты полезный ассистент. Отвечай кратко и по делу.

# Максимальное количество токенов в ответе
# LLM_MAX_TOKENS=2048

# Температура сэмплирования (0.0–2.0)
# LLM_TEMPERATURE=0.7

# Nucleus sampling (0.0–1.0)
# LLM_TOP_P=1.0

# Штраф за повторяющиеся токены (-2.0–2.0)
# LLM_FREQUENCY_PENALTY=0.0

# Штраф за повторяющиеся темы (-2.0–2.0)
# LLM_PRESENCE_PENALTY=0.0

# Seed для воспроизводимых ответов
# LLM_SEED=42

